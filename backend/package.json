{
  "name": "restaurant-chatbot-backend",
  "version": "1.0.0",
  "description": "Multi-tenant WhatsApp chatbot for restaurants",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc && node -e \"const fs=require('fs'),p=require('path');const dst='dist/db/migrations';fs.mkdirSync(dst,{recursive:true});fs.readdirSync('src/db/migrations').forEach(f=>fs.copyFileSync(p.join('src/db/migrations',f),p.join(dst,f)));console.log('SQL migrations copied to dist/')\"",
    "start": "node dist/server.js",
    "migrate": "ts-node src/db/migrate.ts",
    "seed": "ts-node src/db/seed.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.24.0",
    "axios": "^1.6.2",
    "zod": "^3.22.4",
    "express-rate-limit": "^7.1.5",
    "winston": "^3.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/pg": "^8.10.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2"
  }
}
